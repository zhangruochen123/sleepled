.container {
  padding: 20rpx;
}

.header {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.form {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
  margin-bottom: 30rpx;
}

.form-item {
  margin-bottom: 30rpx;
  padding-bottom: 20rpx;
  border-bottom: 1rpx solid #eee;
}

.form-item:last-child {
  border-bottom: none;
}

.label {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 10rpx;
}

.picker {
  padding: 12rpx 16rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  font-size: 16rpx;
}

.quality-selector {
  display: flex;
  gap: 10rpx;
  flex-wrap: wrap;
}

.quality-btn {
  padding: 8rpx 16rpx;
  border-radius: 6rpx;
  background: #f5f5f5;
  border: 1rpx solid #ddd;
  color: #666;
  font-size: 14rpx;
}

.quality-btn.active {
  background: #1296db;
  color: white;
  border-color: #1296db;
}

.submit-btn {
  width: 100%;
  margin: 0;
}
