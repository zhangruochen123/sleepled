/**pages/index/index.wxss**/
.container {
  padding: 20rpx;
}

.header {
  text-align: center;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  display: block;
  color: #1296db;
}

.subtitle {
  font-size: 24rpx;
  color: #999;
  display: block;
  margin-top: 10rpx;
}

.card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.1);
}

.sleep-info {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.label {
  font-size: 24rpx;
  color: #666;
  margin-bottom: 10rpx;
}

.value {
  font-size: 48rpx;
  font-weight: bold;
  color: #1296db;
}

.actions {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}
