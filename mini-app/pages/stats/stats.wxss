/**pages/stats/stats.wxss**/
.container {
  padding: 20rpx;
}

.header {
  font-size: 32rpx;
  font-weight: bold;
  margin-bottom: 30rpx;
}

.time-selector {
  display: flex;
  gap: 10rpx;
  margin-bottom: 30rpx;
}

.period-btn {
  flex: 1;
  padding: 12rpx 0;
  background: white;
  border: 1rpx solid #ddd;
  color: #666;
  font-size: 14rpx;
  border-radius: 8rpx;
}

.period-btn.active {
  background: #1296db;
  color: white;
  border-color: #1296db;
}

.stats-card {
  background: white;
  border-radius: 12rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  display: flex;
  gap: 30rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.label {
  display: block;
  font-size: 20rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.value {
  display: block;
  font-size: 40rpx;
  font-weight: bold;
  color: #1296db;
  margin-bottom: 5rpx;
}

.unit {
  display: block;
  font-size: 16rpx;
  color: #999;
}

.chart-area {
  background: white;
  border-radius: 12rpx;
  padding: 20rpx;
}

.chart-title {
  display: block;
  font-size: 24rpx;
  font-weight: bold;
  margin-bottom: 20rpx;
}

.placeholder {
  height: 300rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #999;
}
