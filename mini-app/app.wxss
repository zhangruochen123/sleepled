/**app.wxss**/
.container {
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: space-between;
  padding: 200rpx 0;
  box-sizing: border-box;
}

page {
  background-color: #f5f5f5;
}

button {
  margin: 20rpx;
  padding: 20rpx 40rpx;
  border-radius: 8rpx;
  background-color: #1296db;
  color: white;
  font-size: 16px;
}

button:active {
  background-color: #0a7ec9;
}
